# ─── LLM API ─────────────────────────────────────────────────────────────────
# Required: OpenAI-compatible API key (DeepSeek, OpenAI, etc.)
OPENAI_API_KEY=sk-your-key-here
# Optional: custom base URL for non-OpenAI providers (e.g. DeepSeek)
OPENAI_BASE_URL=https://api.deepseek.com
# Optional: model name (default: deepseek-chat)
LLM_MODEL_NAME=deepseek-chat

# ─── Telegram Bot ────────────────────────────────────────────────────────────
# Required for telegram_bot module
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
OWNER_TELEGRAM_ID=your-numeric-telegram-id
# Optional: agent API base URL (default: http://localhost:8000/v0)
AGENT_API_BASE_URL=http://127.0.0.1:8000/v0
# Optional: comma-separated group IDs allowed to interact
# ALLOWED_GROUP_IDS=-100123456789

# ─── Defense Config ──────────────────────────────────────────────────────────
# bare = Config0 (no guardrails), l1 = Config1 (L1 only), l1l2 = Config2 (full)
# l1l2l3 = Config3 (L1+L2+L3, requires local chain running)
DEFENSE_CONFIG=l1l2

# ─── Local Chain / Fork (M3) ────────────────────────────────────────────────
ANVIL_PORT=8545
# Comma-separated extra chain IDs for R-17 (local dev only, never set in prod)
EXTRA_ALLOWED_CHAIN_IDS=31337

# ─── Fork Mode (only needed when running: ./scripts/start-chain.sh fork) ────
# ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# FORK_BLOCK_NUMBER=21000000

# ─── Sepolia (optional, demo deployment only) ───────────────────────────────
# SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# DEPLOYER_PRIVATE_KEY=0xYOUR_TESTNET_PRIVATE_KEY
