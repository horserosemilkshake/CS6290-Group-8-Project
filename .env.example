# ─── LLM API ─────────────────────────────────────────────────────────────────
# Required: OpenAI-compatible API key (DeepSeek, OpenAI, etc.)
OPENAI_API_KEY=sk-your-key-here
# Optional: custom base URL for non-OpenAI providers (e.g. DeepSeek)
OPENAI_BASE_URL=https://api.deepseek.com
# Optional: model name (default: deepseek-chat)
LLM_MODEL_NAME=deepseek-chat

# ─── Telegram Bot ────────────────────────────────────────────────────────────
# Required for telegram_bot module
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
OWNER_TELEGRAM_ID=your-numeric-telegram-id
# Optional: agent API base URL (default: http://localhost:8000/v0)
AGENT_API_BASE_URL=http://127.0.0.1:8000/v0
# Optional: comma-separated group IDs allowed to interact
# ALLOWED_GROUP_IDS=-100123456789

# ─── Defense Config ──────────────────────────────────────────────────────────
# bare = Config0 (no guardrails), l1 = Config1 (L1 only), l1l2 = Config2 (full)
# l1l2l3 = Config3 (L1+L2+L3, requires local chain running)
DEFENSE_CONFIG=l1l2

# ─── Tool Coordinator ────────────────────────────────────────────────────────
# false = deterministic mock (canonical benchmark mode); true = live external APIs for smoke/demo
REAL_TOOLS=false
REAL_TOOLS_STRICT=false

# Optional live API credentials
# COINGECKO_DEMO_API_KEY=your-coingecko-demo-key
# COINGECKO_PRO_API_KEY=your-coingecko-pro-key
# ONEINCH_API_KEY=your-1inch-api-key
# COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
# ONEINCH_BASE_URL=https://api.1inch.com
# ONEINCH_SWAP_VERSION=v5.2

# ─── Local Chain / Fork (M3) ────────────────────────────────────────────────
ANVIL_PORT=8545
QUOTE_TTL_SECONDS=120
WALLET_HANDOFF_TTL_SECONDS=300
WALLET_BRIDGE_ADAPTER=in_memory
# Comma-separated extra chain IDs for R-17 (local dev only, never set in prod)
EXTRA_ALLOWED_CHAIN_IDS=31337

# ─── L3 On-Chain Enforcement ────────────────────────────────────────────────
# SwapGuard contract address (printed by start-chain.sh or forge script deploy)
# SWAP_GUARD_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
# RPC URL for L3 eth_call (default: http://127.0.0.1:$ANVIL_PORT)
# Set to Sepolia RPC for public-chain demo:
# L3_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# ─── Fork Mode (only needed when running: ./scripts/start-chain.sh fork) ────
# ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# FORK_BLOCK_NUMBER=21000000

# ─── Sepolia (optional, demo deployment only) ───────────────────────────────
# SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# DEPLOYER_PRIVATE_KEY=0xYOUR_TESTNET_PRIVATE_KEY
